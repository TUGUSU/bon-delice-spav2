# MongoDB connection (required)
DATABASE_URL=mongodb://127.0.0.1:27017/bon_delice

# API server port
PORT=4000

# Optional: append to password before bcrypt (do not commit real values)
PASSWORD_PEPPER=

# Bcrypt cost factor (10–15; default 12)
BCRYPT_ROUNDS=12

# Session cookie TTL in milliseconds (default 7 days)
SESSION_TTL_MS=604800000

# Cookie name for opaque session token
SESSION_COOKIE_NAME=bon_delice_sid

# Set to "true" in HTTPS production
COOKIE_SECURE=false

# Comma-separated browser origins allowed to send credentials (direct API calls)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://bon-delice.netlify.app

# Netlify build only: Express API base URL (no trailing slash), e.g. https://bon-delice-api.onrender.com
# Proxies https://bon-delice.netlify.app/api/* to this host (see scripts/netlify-redirects.js)
# NETLIFY_API_URL=

# Optional: full API path prefix in the built SPA (default /api; use if not using Netlify proxy)
# API_BASE_URL=/api

# Optional: override webpack /api proxy target (default http://127.0.0.1:$PORT from .env)
# API_PROXY_TARGET=http://127.0.0.1:4000

# Lock account after this many failed logins (per username, stored in DB)
LOGIN_MAX_ATTEMPTS=5

# Lockout duration in milliseconds after max failures (default 15 minutes)
LOGIN_LOCKOUT_MS=900000

# If set, creates an admin user on startup when that username does not exist yet.
# Password must meet the same complexity rules as normal registration.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
